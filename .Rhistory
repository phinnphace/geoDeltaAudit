library(dplyr, lib.loc = "/Library/Frameworks/R.framework/Versions/4.5-arm64/Resources/library")
set.seed(42)
# --- 1. True Population (Mu) ---
n <- 1000
true_value <- rnorm(n, mean = 50, sd = 10)
location <- runif(n, 0, 100)
# --- 2. Source Boundaries (Observation) ---
# Aggregate to County (Loss of individual variance)
county <- ifelse(location < 50, "A", "B")
county_mean <- aggregate(true_value ~ county, FUN = mean)$true_value
# --- 3. Crosswalk (Imputation) ---
# Assign County Mean to individuals (Treating Aggregate as Truth)
# This removes all within-county variance
imputed_value <- ifelse(county == "A", county_mean[1], county_mean[2])
# --- 4. Downstream Analysis (The Error) ---
# Calculate SD of True vs. Imputed
sd_true <- sd(true_value)
sd_imputed <- sd(imputed_value)
# Calculate SE for a hypothetical mean test
se_true <- sd_true / sqrt(n)
se_imputed <- sd_imputed / sqrt(n)
# --- Output ---
cat("Accuracy Check: Variance Loss via Crosswalk\n")
cat("===========================================\n")
cat(sprintf("True Data SD: %.3f\n", sd_true))
cat(sprintf("Crosswalked Data SD: %.3f\n", sd_imputed))
cat(sprintf("True Standard Error: %.3f\n", se_true))
cat(sprintf("Crosswalked Standard Error: %.3f\n", se_imputed))
cat("\nCritique: Crosswalked data shows artificially low variance.\n")
cat("Treating this as Mu (truth) creates false certainty in downstream models.\n")
