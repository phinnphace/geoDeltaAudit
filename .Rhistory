# Set seed for reproducibility
set.seed(123)
# Generate a large number of Poisson random variables with mean = 2.3
# Using a larger sample size gives a better estimate
sample_size <- 1000000
samples <- rpois(sample_size, lambda = 2.3)
# Estimate P(Y > 3)
# This counts how many samples are > 3 and divides by total samples
prob_estimate <- sum(samples > 3) / sample_size
