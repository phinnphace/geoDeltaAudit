library(tidyverse)
library(GGally)
library(ggfortify)
library(factoextra)
library(cluster)
library(gridExtra)
library(knitr)
library(ggplot2)
data(iris)
head(iris)
summary_stats <- iris %>%
group_by(Species) %>%
summarise(
Sepal.Length_Mean = round(mean(Sepal.Length), 2),
Sepal.Length_SD   = round(sd(Sepal.Length), 2),
Sepal.Width_Mean  = round(mean(Sepal.Width), 2),
Sepal.Width_SD    = round(sd(Sepal.Width), 2),
Petal.Length_Mean = round(mean(Petal.Length), 2),
Petal.Length_SD   = round(sd(Petal.Length), 2),
Petal.Width_Mean  = round(mean(Petal.Width), 2),
Petal.Width_SD    = round(sd(Petal.Width), 2)
)
kable(summary_stats, caption = "Table 1: Mean and Standard Deviation of Floral Features by Species")
# Pairwise scatterplots and density plots by species
ggpairs(
iris,
columns = 1:4,
aes(color = Species, alpha = 0.7)
)
p1 <- ggplot(iris, aes(x = Species, y = Petal.Length, fill = Species)) +
geom_boxplot() +
labs(title = "Petal Length Distribution by Species", y = "Petal Length (cm)") +
theme_minimal()
print(p1)
p2 <- ggplot(iris, aes(x = Species, y = Sepal.Width, fill = Species)) +
geom_boxplot() +
labs(title = "Sepal Width Distribution by Species", y = "Sepal Width (cm)") +
theme_minimal()
print(p2)
pca_model <- prcomp(iris[, 1:4], scale. = TRUE)
# Print textual summary
summary(pca_model)
# PCA Plot
p3 <- autoplot(pca_model, data = iris, colour = 'Species', frame = TRUE, frame.type = 'norm') +
labs(title = "PCA Colored by Species")
print(p3)
