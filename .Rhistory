# Set seed for reproducibility
set.seed(123)
# Parameters
n <- 50
p <- 0.61
sample_size <- 1000000  # Large sample for accurate estimates
# Generate binomial random variables
# X ~ Binomial(n = 50, p = 0.61)
samples <- rbinom(sample_size, size = n, prob = p)
# a) Probability that X equals 19
prob_equal_19 <- sum(samples == 19) / sample_size
# b) Probability that X is greater than 19
prob_greater_19 <- sum(samples > 19) / sample_size
# c) Probability that X is greater than or equal to 19
prob_greater_equal_19 <- sum(samples >= 19) / sample_size
# d) 90th percentile (value exceeded by 10% of values)
# Sort the samples and find the value at the 90th percentile position
sorted_samples <- sort(samples)
# The 90th percentile means 90% are below this value, so 10% are above
# The smallest x such that P(X > x) < 0.10
percentile_90 <- quantile(samples, probs = 0.90)
phyper(24, m=12000, n=48000, k=100) - phyper(15, m=12000, n=48000, k=100)
